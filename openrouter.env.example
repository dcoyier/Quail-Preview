OPENROUTER_API_KEY=sk-or-v1-replace-me

# Quail v0.7 defaults to this model already; keep it here so the setup is explicit.
QUAIL_EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# Optional: match the Introducing Quail/BRIGHT setup that used DeepInfra through OpenRouter.
QUAIL_OPENROUTER_PROVIDER_ONLY=deepinfra

# Optional: override the local Quail default of 256.
QUAIL_EMBEDDING_BATCH_SIZE=256

# Optional: OpenRouter defaults to 20 concurrent embedding requests.
QUAIL_EMBEDDING_CONCURRENCY=20

# Optional: retry transient empty/malformed/rate-limited embedding responses.
QUAIL_EMBEDDING_MAX_RETRIES=6
QUAIL_EMBEDDING_RETRY_BASE_MS=500

# Optional Ollama-compatible proxy address.
QUAIL_OPENROUTER_EMBED_PROXY_HOST=127.0.0.1
QUAIL_OPENROUTER_EMBED_PROXY_PORT=11435
